<Window x:Class="THBIM.AutoUpdate.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:THBIM.AutoUpdate.ViewModels"
        xmlns:conv="clr-namespace:THBIM.AutoUpdate.Converters"
        Title="THBIM AutoUpdate"
        Width="460" Height="680"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:StatusToColorConverter x:Key="StatusToColor"/>
        <conv:StatusToBackgroundConverter x:Key="StatusToBg"/>
        <conv:StatusToTextConverter x:Key="StatusToText"/>
        <conv:StatusToBorderConverter x:Key="StatusToBorder"/>
    </Window.Resources>

    <Grid>
        <!-- ===== LIQUID ORB BACKGROUND ===== -->
        <Canvas ClipToBounds="True">
            <Ellipse Canvas.Top="-100" Canvas.Right="-100" Width="400" Height="400" Opacity="0.4">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#FFD700" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="0.7"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect><BlurEffect Radius="80"/></Ellipse.Effect>
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="Orb1Translate"/>
                </Ellipse.RenderTransform>
            </Ellipse>
            <Ellipse Canvas.Bottom="-50" Canvas.Left="-50" Width="300" Height="300" Opacity="0.35">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#99FFD700" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="0.7"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect><BlurEffect Radius="80"/></Ellipse.Effect>
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="Orb2Translate"/>
                </Ellipse.RenderTransform>
            </Ellipse>
            <Ellipse Canvas.Top="250" Canvas.Left="180" Width="200" Height="200" Opacity="0.3">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#66FFD700" Offset="0"/>
                        <GradientStop Color="Transparent" Offset="0.7"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect><BlurEffect Radius="80"/></Ellipse.Effect>
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="Orb3Translate"/>
                </Ellipse.RenderTransform>
            </Ellipse>
        </Canvas>

        <!-- ===== MAIN WINDOW BORDER ===== -->
        <Border CornerRadius="24"
                Background="{StaticResource WindowBackgroundGradient}"
                BorderBrush="{StaticResource GlassBorderBrush}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="60" ShadowDepth="25" Opacity="0.5" Color="Black"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Titlebar -->
                    <RowDefinition Height="Auto"/>  <!-- Tab Bar -->
                    <RowDefinition Height="*"/>     <!-- Tab Content -->
                    <RowDefinition Height="Auto"/>  <!-- Action Bar -->
                </Grid.RowDefinitions>

                <!-- ===== TITLEBAR ===== -->
                <Grid Grid.Row="0" MouseLeftButtonDown="Titlebar_MouseLeftButtonDown">
                    <Border Background="#05FFFFFF" BorderBrush="{StaticResource GlassBorderBrush}"
                            BorderThickness="0,0,0,1" Padding="20,16">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- App Icon -->
                                <Border Width="32" Height="32" CornerRadius="8"
                                        Background="{StaticResource GoldGradient}">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.3" Color="#FFD700"/>
                                    </Border.Effect>
                                    <TextBlock Text="TH" FontWeight="ExtraBold" FontSize="14"
                                               Foreground="#0A0A0A" HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold">
                                    <Run Text="THBIM" Foreground="{StaticResource GoldBrush}"/>
                                    <Run Text=" AutoUpdate" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <Run Text=" " /><Run Text="{Binding AppVersionText, Mode=OneWay}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                                </TextBlock>
                            </StackPanel>

                            <!-- Window Controls -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                        VerticalAlignment="Center" Margin="0,0,0,0">
                                <Ellipse Width="12" Height="12" Fill="{StaticResource GoldBrush}"
                                         Margin="0,0,8,0" Cursor="Hand" Opacity="0.7"
                                         MouseLeftButtonDown="Minimize_Click"/>
                                <Ellipse Width="12" Height="12" Fill="{StaticResource SuccessBrush}"
                                         Margin="0,0,8,0" Opacity="0.7"/>
                                <Ellipse Width="12" Height="12" Fill="{StaticResource ErrorBrush}"
                                         Cursor="Hand" Opacity="0.7"
                                         MouseLeftButtonDown="Close_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- ===== TAB BAR ===== -->
                <Border Grid.Row="1" Background="#05FFFFFF" BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal" Margin="18,0">
                        <Border Padding="16,10" Cursor="Hand" MouseLeftButtonDown="TabAddins_Click">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTab}" Value="0">
                                            <Setter Property="BorderBrush" Value="{StaticResource GoldBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="Addins" FontSize="13" FontWeight="Medium">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTab}" Value="0">
                                                <Setter Property="Foreground" Value="{StaticResource GoldBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                        <Border Padding="16,10" Cursor="Hand" MouseLeftButtonDown="TabAccount_Click">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTab}" Value="1">
                                            <Setter Property="BorderBrush" Value="{StaticResource GoldBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="Account" FontSize="13" FontWeight="Medium">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SelectedTab}" Value="1">
                                                <Setter Property="Foreground" Value="{StaticResource GoldBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- ===== TAB CONTENT ===== -->
                <Grid Grid.Row="2">

                <!-- ===== ADDINS TAB ===== -->
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedTab}" Value="1">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                <!-- ===== STATUS BANNER ===== -->
                <Border Grid.Row="0" Margin="16,16,16,0" Padding="14,14" CornerRadius="16"
                        BorderThickness="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1EFFD700" Offset="0"/>
                            <GradientStop Color="#0AFFD700" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#26FFD700"/>
                    </Border.BorderBrush>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Status Dot -->
                        <Ellipse x:Name="StatusDot" Grid.Column="0" Width="10" Height="10"
                                 Margin="0,0,12,0" VerticalAlignment="Center">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="{StaticResource SuccessBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="False">
                                            <Setter Property="Fill" Value="{StaticResource ErrorBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                            <Ellipse.Effect>
                                <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#34C759" Opacity="0.5"/>
                            </Ellipse.Effect>
                        </Ellipse>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="CONNECTION" FontSize="11" FontWeight="Normal"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       />
                            <TextBlock Text="{Binding StatusText}" FontSize="13" FontWeight="Medium"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <Border Grid.Column="2" Padding="10,4" CornerRadius="8" VerticalAlignment="Center"
                                Background="#26FFD700">
                            <TextBlock Text="{Binding VersionText}" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource GoldBrush}"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- ===== SECTION HEADER ===== -->
                <Grid Grid.Row="1" Margin="20,16,20,8">
                    <TextBlock Text="Installed Addins" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                    <Border HorizontalAlignment="Right" Padding="8,2" CornerRadius="6"
                            Background="#1AFFD700">
                        <TextBlock FontSize="11" FontWeight="Medium" Foreground="{StaticResource GoldBrush}">
                            <Run Text="{Binding AddinCount, Mode=OneWay}"/>
                            <Run Text=" addins"/>
                        </TextBlock>
                    </Border>
                </Grid>

                <!-- ===== UP TO DATE MESSAGE + RELEASE HISTORY ===== -->
                <Border Grid.Row="2" Margin="16,20,16,12" Padding="16,16,16,12" CornerRadius="14"
                        Background="{StaticResource GlassBrush}"
                        BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding UpdatesAvailableCount}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <StackPanel Grid.Row="0" HorizontalAlignment="Center">
                            <TextBlock Text="✓" FontSize="28" Foreground="{StaticResource SuccessBrush}"
                                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <TextBlock Text="All addins are up to date" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                            <TextBlock FontSize="12" Foreground="{StaticResource TextTertiaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,4,0,0">
                                <Run Text="THBIM Revit Tools"/>
                                <Run Text="{Binding VersionText, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Divider -->
                        <Border Grid.Row="1" Height="1" Margin="0,14,0,10"
                                Background="{StaticResource GlassBorderBrush}"
                                Visibility="{Binding HasReleaseHistory, Converter={StaticResource BoolToVis}}"/>

                        <!-- Section Label -->
                        <Grid Grid.Row="2" Margin="0,0,0,6"
                              Visibility="{Binding HasReleaseHistory, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Release History" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <Border HorizontalAlignment="Right" Padding="6,1" CornerRadius="4"
                                    Background="#1AFFD700">
                                <TextBlock FontSize="10" Foreground="{StaticResource GoldBrush}"
                                           Text="Last 10 releases"/>
                            </Border>
                        </Grid>

                        <!-- History list -->
                        <ScrollViewer Grid.Row="3" MaxHeight="280" VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding HasReleaseHistory, Converter={StaticResource BoolToVis}}">
                            <ItemsControl ItemsSource="{Binding ReleaseHistory}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,6" Padding="10,8" CornerRadius="10"
                                                Background="#08FFFFFF"
                                                BorderBrush="#14FFFFFF" BorderThickness="1">
                                            <StackPanel>
                                                <Grid>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding VersionDisplay}"
                                                                   FontSize="12" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource GoldBrush}"/>
                                                        <Border Padding="5,1" CornerRadius="4" Margin="8,0,0,0"
                                                                Background="#2634C759"
                                                                Visibility="{Binding IsCurrent, Converter={StaticResource BoolToVis}}">
                                                            <TextBlock Text="Installed" FontSize="9"
                                                                       Foreground="{StaticResource SuccessBrush}"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding DateDisplay}" FontSize="10"
                                                               Foreground="{StaticResource TextTertiaryBrush}"
                                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                </Grid>
                                                <ItemsControl ItemsSource="{Binding ChangelogLines}" Margin="0,4,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,1,0,1">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Text="•" Margin="0,0,6,0"
                                                                           Foreground="{StaticResource TextTertiaryBrush}"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding}"
                                                                           FontSize="11"
                                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                                           TextWrapping="Wrap"/>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- ===== ADDINS LIST (only when updates available) ===== -->
                <ScrollViewer Grid.Row="2" Padding="12,4">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer" BasedOn="{StaticResource GlassScrollViewer}">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding UpdatesAvailableCount}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                    <ItemsControl ItemsSource="{Binding Addins}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:AddinCardViewModel}">
                                <Border Margin="0,0,0,6" Padding="12,12" CornerRadius="14"
                                        Background="{StaticResource GlassBrush}"
                                        BorderBrush="{Binding Status, Converter={StaticResource StatusToBorder}}"
                                        BorderThickness="1"
                                        Cursor="Hand">
                                    <Border.Triggers>
                                        <EventTrigger RoutedEvent="MouseEnter">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                    To="#1AFFFFFF" Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                        <EventTrigger RoutedEvent="MouseLeave">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                    To="#0DFFFFFF" Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Border.Triggers>

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Top Row: Icon, Name, Status -->
                                        <Grid Grid.Row="0" Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="10"
                                                    Margin="0,0,10,0"
                                                    Background="#33FFD700" BorderBrush="#26FFD700" BorderThickness="1">
                                                <TextBlock Text="◆" FontSize="16" Foreground="{StaticResource GoldBrush}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Description}" FontSize="11"
                                                           Foreground="{StaticResource TextTertiaryBrush}" Margin="0,1,0,0"/>
                                            </StackPanel>

                                            <Border Grid.Column="2" Padding="8,3" CornerRadius="6"
                                                    Background="{Binding Status, Converter={StaticResource StatusToBg}}"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Status, Converter={StaticResource StatusToText}}"
                                                           FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{Binding Status, Converter={StaticResource StatusToColor}}"
                                                           />
                                            </Border>
                                        </Grid>

                                        <!-- Version Info -->
                                        <TextBlock Grid.Row="1" Text="{Binding VersionDisplay}"
                                                   FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>

                                        <!-- Changelog (visible when update available) -->
                                        <TextBlock Grid.Row="2" Margin="0,4,0,0"
                                                   Text="{Binding Changelog}" FontSize="10" FontStyle="Italic"
                                                   Foreground="{StaticResource GoldBrush}" Opacity="0.7"
                                                   TextTrimming="CharacterEllipsis"
                                                   Visibility="{Binding ShowChangelog, Converter={StaticResource BoolToVis}}"/>

                                        <!-- Progress Bar (visible when updating) -->
                                        <Grid Grid.Row="3" Margin="0,8,0,0"
                                              Visibility="{Binding ShowProgress, Converter={StaticResource BoolToVis}}">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <ProgressBar Grid.Row="0" Height="3"
                                                         Minimum="0" Maximum="1"
                                                         Value="{Binding DownloadProgress, Mode=OneWay}"
                                                         Background="#0FFFFFFF"
                                                         Foreground="{StaticResource GoldBrush}"
                                                         BorderThickness="0"/>

                                            <TextBlock Grid.Row="1" Text="{Binding ProgressText}"
                                                       FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"
                                                       Margin="0,4,0,0"/>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                </Grid><!-- End Addins Tab -->

                <!-- ===== ACCOUNT TAB ===== -->
                <ScrollViewer DataContext="{Binding AccountVM}">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer" BasedOn="{StaticResource GlassScrollViewer}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DataContext.SelectedTab, RelativeSource={RelativeSource AncestorType=Window}}" Value="1">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>

                    <Grid Margin="16,16,16,16">
                        <!-- LOGIN STATE -->
                        <StackPanel HorizontalAlignment="Center"
                                    Visibility="{Binding ShowLogin, Converter={StaticResource BoolToVis}}">
                            <StackPanel.Resources>
                                <Style TargetType="TextBox">
                                    <Setter Property="Background" Value="#0DFFFFFF"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderBrush" Value="#1AFFFFFF"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Padding" Value="12,10"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="CaretBrush" Value="{StaticResource GoldBrush}"/>
                                </Style>
                                <Style TargetType="PasswordBox">
                                    <Setter Property="Background" Value="#0DFFFFFF"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="BorderBrush" Value="#1AFFFFFF"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Padding" Value="12,10"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="CaretBrush" Value="{StaticResource GoldBrush}"/>
                                </Style>
                            </StackPanel.Resources>

                            <!-- Avatar -->
                            <Border Width="70" Height="70" CornerRadius="35" Margin="0,30,0,16"
                                    HorizontalAlignment="Center"
                                    Background="#1AD4A44A" BorderBrush="#33D4A44A" BorderThickness="2">
                                <TextBlock Text="👤" FontSize="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Welcome to THBIM" FontSize="18" FontWeight="SemiBold"
                                       Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Sign in to manage your addins &amp; license" FontSize="12"
                                       Foreground="{StaticResource TextTertiaryBrush}" HorizontalAlignment="Center"
                                       Margin="0,4,0,24"/>

                            <!-- Email -->
                            <TextBlock Text="EMAIL" FontSize="10" FontWeight="Medium" Margin="0,0,0,6"
                                       Foreground="{StaticResource TextTertiaryBrush}" />
                            <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                            <!-- Password -->
                            <TextBlock Text="PASSWORD" FontSize="10" FontWeight="Medium" Margin="0,0,0,6"
                                       Foreground="{StaticResource TextTertiaryBrush}"/>
                            <PasswordBox x:Name="PasswordBox" Margin="0,0,0,8"
                                         PasswordChanged="PasswordBox_PasswordChanged"/>

                            <!-- Error message -->
                            <TextBlock Text="{Binding StatusMessage}" FontSize="12" Margin="0,0,0,8"
                                       TextWrapping="Wrap" HorizontalAlignment="Center"
                                       Visibility="{Binding IsError, Converter={StaticResource BoolToVis}}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- Privacy consent (GDPR Art. 7) — Sign In is gated on this -->
                            <CheckBox IsChecked="{Binding HasConsented, Mode=TwoWay}"
                                      Margin="0,8,0,4"
                                      Foreground="{StaticResource TextSecondaryBrush}">
                                <CheckBox.Content>
                                    <TextBlock TextWrapping="Wrap" FontSize="12">
                                        <Run Text="I have read and agree to the "/>
                                        <Hyperlink Foreground="{StaticResource GoldBrush}" TextDecorations="Underline"
                                                   Click="PrivacyPolicy_Click">Privacy Policy</Hyperlink>
                                        <Run Text="."/>
                                    </TextBlock>
                                </CheckBox.Content>
                            </CheckBox>

                            <!-- Login Button -->
                            <Button Command="{Binding LoginCommand}" Cursor="Hand" Margin="0,4,0,0"
                                    FontSize="15" FontWeight="Bold">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border CornerRadius="12" Padding="14"
                                                Background="{StaticResource GoldButtonGradient}">
                                            <TextBlock Text="Sign In" HorizontalAlignment="Center"
                                                       FontWeight="Bold" FontSize="15" Foreground="#0A0A0A"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Opacity" Value="0.5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Sign Up link -->
                            <TextBlock HorizontalAlignment="Center" Margin="0,14,0,0" FontSize="12"
                                       Foreground="{StaticResource TextTertiaryBrush}">
                                <Run Text="Don't have an account? "/>
                                <Hyperlink Foreground="{StaticResource GoldBrush}" TextDecorations="None"
                                           Click="SignUp_Click">Sign up at thbim.pages.dev →</Hyperlink>
                            </TextBlock>

                            <!-- Privacy notice (GDPR Art. 13) -->
                            <TextBlock HorizontalAlignment="Center" Margin="0,8,0,0" FontSize="11"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       TextWrapping="Wrap" TextAlignment="Center">
                                <Run Text="By signing in you accept our "/>
                                <Hyperlink Foreground="{StaticResource GoldBrush}" TextDecorations="Underline"
                                           Click="PrivacyPolicy_Click">Privacy Policy</Hyperlink>
                                <Run Text="."/>
                            </TextBlock>
                        </StackPanel>

                        <!-- PROFILE STATE -->
                        <StackPanel Visibility="{Binding ShowProfile, Converter={StaticResource BoolToVis}}">
                            <!-- Profile Card -->
                            <Border Padding="16" CornerRadius="16" Margin="0,0,0,12"
                                    Background="{StaticResource GlassBrush}"
                                    BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                        <Border Width="46" Height="46" CornerRadius="23"
                                                Background="{StaticResource GoldGradient}">
                                            <TextBlock Text="{Binding Initials}" FontSize="16" FontWeight="ExtraBold"
                                                       Foreground="#0A0A0A" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FullName}" FontSize="15" FontWeight="SemiBold"
                                                       Foreground="White"/>
                                            <TextBlock Text="{Binding Email}" FontSize="12"
                                                       Foreground="{StaticResource TextTertiaryBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Status Grid -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" Padding="12" CornerRadius="10" Margin="0,0,6,0"
                                                Background="#08FFFFFF" BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock Text="STATUS" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"
                                                           Margin="0,0,0,6"/>
                                                <Border Padding="6,2" CornerRadius="10" HorizontalAlignment="Left">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="#1AFFFFFF"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsPremium}" Value="True">
                                                                    <Setter Property="Background" Value="#33D4A44A"/>
                                                                    <Setter Property="BorderBrush" Value="#4DD4A44A"/>
                                                                    <Setter Property="BorderThickness" Value="1"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding TierDisplay}" FontSize="11" FontWeight="Bold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsPremium}" Value="True">
                                                                        <Setter Property="Foreground" Value="{StaticResource GoldBrush}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="1" Padding="12" CornerRadius="10" Margin="6,0,0,0"
                                                Background="#08FFFFFF" BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock Text="EXPIRES" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"
                                                           Margin="0,0,0,6"/>
                                                <TextBlock Text="{Binding ExpiryDisplay}" FontSize="13" FontWeight="SemiBold"
                                                           Foreground="{StaticResource SuccessBrush}"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- License Key Section -->
                            <Border Padding="16" CornerRadius="16" Margin="0,0,0,12"
                                    Background="{StaticResource GlassBrush}"
                                    BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="ACTIVATE LICENSE KEY" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,10"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding LicenseKey, UpdateSourceTrigger=PropertyChanged}"
                                                 FontFamily="Consolas" FontSize="13" Margin="0,0,8,0"
                                                 Background="#0DFFFFFF" Foreground="White"
                                                 BorderBrush="#1AFFFFFF" BorderThickness="1" Padding="10,8"
                                                 CaretBrush="{StaticResource GoldBrush}"/>
                                        <Button Grid.Column="1" Command="{Binding ApplyKeyCommand}" Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border CornerRadius="10" Padding="16,8"
                                                            Background="{StaticResource GoldButtonGradient}">
                                                        <TextBlock Text="Activate" FontWeight="Bold" FontSize="13"
                                                                   Foreground="#0A0A0A"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter Property="Opacity" Value="0.5"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>
                                    <!-- Status message -->
                                    <TextBlock Text="{Binding StatusMessage}" FontSize="11" Margin="0,8,0,0"
                                               TextWrapping="Wrap"
                                               Visibility="{Binding StatusMessage, Converter={StaticResource BoolToVis}}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsError}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Machine ID -->
                            <Border Padding="12" CornerRadius="12" Margin="0,0,0,12"
                                    Background="#05FFFFFF" BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="1">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="MACHINE ID" FontSize="10"
                                                   Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,4"/>
                                        <TextBlock Text="{Binding MachineId}" FontSize="12" FontFamily="Consolas"
                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </StackPanel>
                                    <Button HorizontalAlignment="Right" VerticalAlignment="Center" Cursor="Hand"
                                            Click="CopyMachineId_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Padding="8,4" CornerRadius="6"
                                                        Background="#0DFFFFFF" BorderBrush="#1AFFFFFF" BorderThickness="1">
                                                    <TextBlock x:Name="CopyText" Text="Copy" FontSize="10"
                                                               Foreground="{StaticResource TextTertiaryBrush}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="CopyText" Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>

                            <!-- Sign Out -->
                            <Button Command="{Binding LogoutCommand}" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="LogoutBorder" CornerRadius="12" Padding="12"
                                                Background="Transparent"
                                                BorderBrush="#1AFFFFFF" BorderThickness="1">
                                            <TextBlock Text="Sign Out" FontSize="13" FontWeight="Medium"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       HorizontalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="LogoutBorder" Property="BorderBrush" Value="#4DFF453A"/>
                                                <Setter TargetName="LogoutBorder" Property="Background" Value="#0DFF453A"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                </Grid><!-- End Tab Content -->

                <!-- ===== ACTION BAR ===== -->
                <Border Grid.Row="3" BorderBrush="{StaticResource GlassBorderBrush}"
                        BorderThickness="0,1,0,0" Background="#33000000"
                        Padding="16,12,16,16">
                    <StackPanel>
                        <!-- Update All Button -->
                        <Button Command="{Binding UpdateAllCommand}" Cursor="Hand"
                                FontSize="14" FontWeight="SemiBold" Padding="14"
                                Foreground="#0A0A0A">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="BtnBorder" CornerRadius="14" Padding="{TemplateBinding Padding}"
                                            Background="{StaticResource GoldButtonGradient}">
                                        <Border.Effect>
                                            <DropShadowEffect BlurRadius="15" ShadowDepth="4" Opacity="0.25" Color="#FFD700"/>
                                        </Border.Effect>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="BtnBorder" Property="RenderTransform">
                                                <Setter.Value>
                                                    <TranslateTransform Y="-2"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="BtnBorder" Property="Opacity" Value="0.6"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="{Binding UpdateButtonText}" FontWeight="SemiBold" FontSize="14"
                                       Foreground="#0A0A0A"/>
                        </Button>

                        <!-- Meta Row -->
                        <Grid Margin="4,10,4,0">
                            <TextBlock Text="{Binding LastCheckedText}" FontSize="11"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       VerticalAlignment="Center"/>

                            <Button HorizontalAlignment="Right" Cursor="Hand"
                                    Command="{Binding OpenSettingsCommand}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="SettBorder" Padding="10,5" CornerRadius="8"
                                                Background="Transparent"
                                                BorderBrush="{StaticResource GlassBorderBrush}"
                                                BorderThickness="1">
                                            <TextBlock Text="⚙ Settings" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="SettBorder" Property="BorderBrush"
                                                        Value="#4DFFD700"/>
                                                <Setter TargetName="SettBorder" Property="Background"
                                                        Value="#0DFFD700"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ===== SETTINGS OVERLAY ===== -->
                <Grid Grid.Row="0" Grid.RowSpan="4"
                      Visibility="{Binding IsSettingsOpen, Converter={StaticResource BoolToVis}}">
                    <!-- Backdrop -->
                    <Border Background="#99000000" CornerRadius="24"
                            MouseLeftButtonDown="SettingsOverlay_Close"/>

                    <!-- Settings Modal -->
                    <Border Width="380" CornerRadius="20" VerticalAlignment="Center"
                            Background="#F2191919" BorderBrush="{StaticResource GlassBorderBrush}"
                            BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="80" ShadowDepth="25" Opacity="0.5" Color="Black"/>
                        </Border.Effect>

                        <StackPanel>
                            <!-- Modal Header -->
                            <Grid Margin="20,20,20,12">
                                <TextBlock Text="⚙ Settings" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <Button HorizontalAlignment="Right" Cursor="Hand"
                                        Command="{Binding CloseSettingsCommand}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="CloseBorder" Width="28" Height="28" CornerRadius="8"
                                                    Background="#0FFFFFFF">
                                                <TextBlock Text="✕" FontSize="14"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="CloseBorder" Property="Background" Value="#26FF453A"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>

                            <!-- Settings Items -->
                            <StackPanel Margin="20,4,20,20" DataContext="{Binding SettingsVM}">
                                <!-- Auto Update -->
                                <Grid Margin="0,0,0,0">
                                    <Border BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="0,0,0,1"
                                            Padding="0,12">
                                        <Grid>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Auto Update" FontSize="13"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock Text="Download &amp; install automatically" FontSize="11"
                                                           Foreground="{StaticResource TextTertiaryBrush}" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <ToggleButton HorizontalAlignment="Right"
                                                          Style="{StaticResource GoldToggle}"
                                                          IsChecked="{Binding AutoUpdate}"/>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <!-- Start with Windows -->
                                <Border BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="0,0,0,1"
                                        Padding="0,12">
                                    <Grid>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Start with Windows" FontSize="13"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="Run on system startup" FontSize="11"
                                                       Foreground="{StaticResource TextTertiaryBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <ToggleButton HorizontalAlignment="Right"
                                                      Style="{StaticResource GoldToggle}"
                                                      IsChecked="{Binding StartWithWindows}"/>
                                    </Grid>
                                </Border>

                                <!-- Notifications -->
                                <Border BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="0,0,0,1"
                                        Padding="0,12">
                                    <Grid>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Notifications" FontSize="13"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="Show toast on update" FontSize="11"
                                                       Foreground="{StaticResource TextTertiaryBrush}" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <ToggleButton HorizontalAlignment="Right"
                                                      Style="{StaticResource GoldToggle}"
                                                      IsChecked="{Binding Notifications}"/>
                                    </Grid>
                                </Border>

                                <!-- Check Interval -->
                                <Border BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="0,0,0,1"
                                        Padding="0,12">
                                    <Grid>
                                        <TextBlock Text="Check Interval" FontSize="13"
                                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                        <ComboBox HorizontalAlignment="Right"
                                                  ItemsSource="{Binding IntervalOptions}"
                                                  SelectedItem="{Binding SelectedInterval}"
                                                  DisplayMemberPath="Label"
                                                  Style="{StaticResource GlassComboBox}"/>
                                    </Grid>
                                </Border>

                                <!-- Repository Info -->
                                <Border BorderBrush="{StaticResource GlassBorderBrush}" BorderThickness="0,0,0,1"
                                        Padding="0,12">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Server" FontSize="13"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding RepoInfo}" FontSize="11"
                                                   Foreground="{StaticResource TextTertiaryBrush}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Check for Updates Now -->
                                <Grid Margin="0,16,0,0">
                                    <Button Content="Check for Updates"
                                            HorizontalAlignment="Stretch"
                                            Height="36" FontSize="13" FontWeight="SemiBold"
                                            Cursor="Hand" BorderThickness="0"
                                            Foreground="#1a1a1a"
                                            Command="{Binding DataContext.CheckForUpdatesCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                                        <Button.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#FFD700" Offset="0"/>
                                                <GradientStop Color="#FFA500" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Button.Background>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                        CornerRadius="8" Padding="16,0">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>

                                <!-- Delete My Data (GDPR Art. 17) -->
                                <Grid Margin="0,12,0,0">
                                    <Button Content="Delete My Data"
                                            HorizontalAlignment="Stretch"
                                            Height="36" FontSize="13" FontWeight="SemiBold"
                                            Cursor="Hand" BorderThickness="1"
                                            Foreground="#E5C07B" Background="Transparent"
                                            BorderBrush="#33E5C07B"
                                            ToolTip="GDPR Art. 17 — remove all locally stored account data, session cache, and logs."
                                            Command="{Binding ClearAllDataCommand}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="8" Padding="16,0">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#22E5C07B"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>

                                <!-- Uninstall -->
                                <Grid Margin="0,12,0,0">
                                    <Button Content="Uninstall THBIM"
                                            HorizontalAlignment="Stretch"
                                            Height="36" FontSize="13" FontWeight="SemiBold"
                                            Cursor="Hand" BorderThickness="1"
                                            Foreground="#FF6666" Background="Transparent"
                                            BorderBrush="#55FF6666"
                                            Command="{Binding DataContext.UninstallCommand, RelativeSource={RelativeSource AncestorType=Window}}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="8" Padding="16,0">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="#33FF6666"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

            </Grid>
        </Border>

        <!-- ===== ORB ANIMATIONS ===== -->
        <Grid.Triggers>
            <EventTrigger RoutedEvent="Loaded">
                <BeginStoryboard>
                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                        <DoubleAnimation Storyboard.TargetName="Orb1Translate" Storyboard.TargetProperty="X"
                                         From="0" To="30" Duration="0:0:18">
                            <DoubleAnimation.EasingFunction><SineEase/></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetName="Orb1Translate" Storyboard.TargetProperty="Y"
                                         From="0" To="-40" Duration="0:0:18">
                            <DoubleAnimation.EasingFunction><SineEase/></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>

                        <DoubleAnimation Storyboard.TargetName="Orb2Translate" Storyboard.TargetProperty="X"
                                         From="0" To="-20" Duration="0:0:22" BeginTime="0:0:5">
                            <DoubleAnimation.EasingFunction><SineEase/></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetName="Orb2Translate" Storyboard.TargetProperty="Y"
                                         From="0" To="20" Duration="0:0:22" BeginTime="0:0:5">
                            <DoubleAnimation.EasingFunction><SineEase/></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>

                        <DoubleAnimation Storyboard.TargetName="Orb3Translate" Storyboard.TargetProperty="X"
                                         From="0" To="40" Duration="0:0:25" BeginTime="0:0:10">
                            <DoubleAnimation.EasingFunction><SineEase/></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetName="Orb3Translate" Storyboard.TargetProperty="Y"
                                         From="0" To="30" Duration="0:0:25" BeginTime="0:0:10">
                            <DoubleAnimation.EasingFunction><SineEase/></DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Grid.Triggers>
    </Grid>
</Window>
