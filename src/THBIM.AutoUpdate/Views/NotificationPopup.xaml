<Window x:Class="THBIM.AutoUpdate.Views.NotificationPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="THBIM AutoUpdate"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        MaxWidth="480">

    <Window.Resources>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="20,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer border with glow effect -->
    <Border CornerRadius="16" Margin="20">
        <Border.Effect>
            <DropShadowEffect Color="#FFD700" BlurRadius="30" ShadowDepth="0" Opacity="0.4"/>
        </Border.Effect>
        <Border CornerRadius="16" Background="#E8181818" BorderBrush="#55FFD700" BorderThickness="1.5">
            <Grid>
                <!-- Close button -->
                <Button x:Name="CloseBtn" Content="✕"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,12,16,0" Background="Transparent" BorderThickness="0"
                        Foreground="#888" FontSize="14" Cursor="Hand"
                        Click="Close_Click"/>

                <StackPanel Margin="32,28,32,28">
                    <!-- Icon + Title -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,16">
                        <!-- TH Logo placeholder -->
                        <Border Width="44" Height="44" CornerRadius="10"
                                Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FFD700" Offset="0"/>
                                    <GradientStop Color="#B8860B" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="TH" Foreground="#1a1a1a" FontSize="18" FontWeight="Black"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="TitleText" Text="THBIM AutoUpdate"
                                       Foreground="White" FontSize="18" FontWeight="Bold"/>
                            <TextBlock x:Name="SubtitleText" Text=""
                                       Foreground="#FFD700" FontSize="12" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Separator -->
                    <Border Height="1" Background="#33FFD700" Margin="0,0,0,16"/>

                    <!-- Message -->
                    <TextBlock x:Name="MessageText" Text=""
                               Foreground="#CCCCCC" FontSize="14" TextWrapping="Wrap"
                               TextAlignment="Center" LineHeight="22" Margin="0,0,0,20"/>

                    <!-- Changelog area (hidden by default) -->
                    <TextBlock x:Name="ChangelogText" Text=""
                               Foreground="#999999" FontSize="12" TextWrapping="Wrap"
                               TextAlignment="Left" LineHeight="20" Margin="8,0,8,16"
                               Visibility="Collapsed"/>

                    <!-- Progress area (hidden by default) -->
                    <StackPanel x:Name="ProgressPanel" Visibility="Collapsed" Margin="0,0,0,16">
                        <ProgressBar x:Name="ProgressBar" Height="6" Minimum="0" Maximum="100"
                                     Background="#333" Foreground="#FFD700" BorderThickness="0">
                            <ProgressBar.Clip>
                                <RectangleGeometry Rect="0,0,400,6" RadiusX="3" RadiusY="3"/>
                            </ProgressBar.Clip>
                        </ProgressBar>
                        <TextBlock x:Name="ProgressText" Text="Downloading..."
                                   Foreground="#888" FontSize="11" Margin="0,6,0,0"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Buttons -->
                    <StackPanel x:Name="ButtonPanel" Orientation="Horizontal"
                                HorizontalAlignment="Center" Margin="0,4,0,0">
                        <!-- Buttons added dynamically -->
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>
